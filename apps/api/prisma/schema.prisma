// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  active
  inactive
}

enum ProductType {
  standard
  vintage
  refurbished
}

enum ProductStatus {
  active
  inactive
  archived
}

enum ChannelType {
  shopify
  idealo
  marketplace
  manual
  other
}

enum ChannelStatus {
  active
  inactive
}

enum WarehouseType {
  own
  external
  returns
}

enum WarehouseStatus {
  active
  inactive
}

enum LotSourceType {
  manual_init
  manual_receipt
}

enum LotStatus {
  available
  held
  non_sellable
  repair
}

enum MovementType {
  lot_create
  manual_adjust
  sale_out
  return_in
  transfer_out
  transfer_in
}

enum EanAliasSource {
  manual
  marketplace
  worten
  idealo
  shopify
  other
}

model HoldingCompany {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores Store[]

  @@map("holding_companies")
}

model Store {
  id        String      @id @default(cuid())
  holdingId String
  code      String
  name      String
  status    StoreStatus @default(active)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  holding HoldingCompany @relation(fields: [holdingId], references: [id])

  products   Product[]
  warehouses Warehouse[]
  channels   SalesChannel[]

  memberships     UserStoreMembership[]
  userPermissions UserPermission[]

  @@unique([holdingId, code])
  @@map("stores")
}

model Product {
  id      String        @id @default(cuid())
  storeId String
  ean     String
  brand   String
  model   String
  type    ProductType   @default(standard)
  status  ProductStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, ean])
  @@map("products")
}

model Warehouse {
  id      String @id @default(cuid())
  storeId String
  code    String
  name    String

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, code])
  @@map("warehouses")
}

model SalesChannel {
  id      String      @id @default(cuid())
  storeId String
  code    String
  name    String
  type    ChannelType

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, code])
  @@map("sales_channels")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  preferredLocale String   @default("es")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships   UserStoreMembership[]
  permissions   UserPermission[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model UserStoreMembership {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  roleKey   String // "admin", "warehouse", "ops"
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId, roleKey])
  @@map("user_store_memberships")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique // "inventory.read", "products.write", etc.
  description String?

  userPermissions UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  storeId      String
  permissionId String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId, permissionId])
  @@index([storeId, userId])
  @@map("user_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

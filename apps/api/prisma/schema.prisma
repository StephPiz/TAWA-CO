generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  active
  inactive
}

enum ProductType {
  watch
  bag
  perfume
  accessory
  vintage
  refurbished
  other
}

enum ProductStatus {
  active
  inactive
  archived
}

enum ChannelType {
  shopify
  idealo
  marketplace
  manual
  other
}

enum ChannelStatus {
  active
  inactive
}

enum WarehouseType {
  own
  external
  returns
}

enum WarehouseStatus {
  active
  inactive
}

enum LotSourceType {
  manual_init
  manual_receipt
  purchase_order
  return_restock
}

enum LotStatus {
  available
  held
  non_sellable
  repair
}

enum MovementType {
  lot_create
  receive_in
  manual_adjust
  sale_out
  return_in
  transfer_out
  transfer_in
}

enum EanAliasSource {
  manual
  marketplace
  idealo
  shopify
  other
}

enum ChannelListingStatus {
  active
  inactive
}

enum OrderStatus {
  pending
  paid
  backorder
  packed
  shipped
  delivered
  returned
  cancelled
}

enum PaymentStatus {
  unpaid
  partially_paid
  paid
}

enum InvoiceStatus {
  draft
  issued
  cancelled
}

enum ReturnStatus {
  pending_review
  processed
}

enum ReturnDecision {
  restock
  discount
  repair
  scrap
}

enum BackorderStatus {
  open
  fulfilled
  cancelled
}

enum PurchaseOrderStatus {
  draft
  sent
  priced
  paid
  preparing
  checklist
  tracking_received
  in_transit
  received
  verified
  closed
  incident
}

enum ThreePlLegStatus {
  planned
  in_transit
  delivered
  delayed
}

enum TaskStatus {
  open
  in_progress
  blocked
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum PresenceStatus {
  online
  away
  offline
}

enum ChatChannelType {
  public
  direct
}

enum NotificationType {
  task_assigned
  purchase_received
  backorder_created
  return_processed
  system
}

enum NotificationSeverity {
  info
  warning
  critical
}

enum IntegrationEventStatus {
  received
  processed
  failed
  ignored
  duplicate
}

enum IntegrationOutboxStatus {
  pending
  processing
  sent
  failed
  dead
}

enum SupportTicketStatus {
  open
  in_progress
  waiting_customer
  resolved
  closed
}

enum SupportTicketPriority {
  low
  medium
  high
  urgent
}

model HoldingCompany {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores Store[]

  @@map("holding_companies")
}

model Store {
  id                  String      @id @default(cuid())
  holdingId           String
  code                String
  name                String
  status              StoreStatus @default(active)
  description         String?
  logoUrl             String?
  themeColor          String?
  baseCurrencyCode    String      @default("EUR")
  invoicePrefix       String?
  invoiceSequenceNext Int         @default(1)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  holding HoldingCompany @relation(fields: [holdingId], references: [id])

  products          Product[]
  eanAliases        EanAlias[]
  warehouses        Warehouse[]
  channels          SalesChannel[]
  memberships       UserStoreMembership[]
  userPermissions   UserPermission[]
  inventoryLots     InventoryLot[]
  movements         InventoryMovement[]
  storeCurrencies   StoreCurrency[]
  fxRates           FxRate[]
  productOverrides  ProductText[]
  customers         Customer[]
  salesOrders       SalesOrder[]
  salesOrderItems   SalesOrderItem[]
  payouts           Payout[]
  payoutMatches     PayoutOrderMatch[]
  invoices          Invoice[]
  returns           ReturnCase[]
  backorders        BackorderLine[]
  suppliers         Supplier[]
  purchaseOrders    PurchaseOrder[]
  purchasePayments  PurchaseOrderPayment[]
  threePlShipments  ThreePlShipment[]
  PurchaseOrderItem PurchaseOrderItem[]
  tasks             TeamTask[]
  presences         UserPresence[]
  chatChannels      ChatChannel[]
  chatMessages      ChatMessage[]
  notifications     Notification[]
  supportTickets    SupportTicket[]
  auditLogs         AuditLog[]
  auditAnchors      AuditAnchor[]
  integrations      StoreIntegration[]
  webhookEvents     IntegrationWebhookEvent[]
  outboxEvents      IntegrationOutboxEvent[]

  @@unique([holdingId, code])
  @@map("stores")
}

model Product {
  id                  String        @id @default(cuid())
  storeId             String
  ean                 String
  sku                 String?
  type                ProductType   @default(other)
  brand               String
  model               String
  name                String
  status              ProductStatus @default(active)
  isInternalEan       Boolean       @default(false)
  internalDescription String?
  attributes          Json?
  mainImageUrl        String?
  modelRef            String?
  category            String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  store         Store                 @relation(fields: [storeId], references: [id])
  eanAliases    EanAlias[]
  images        ProductImage[]
  listings      ProductChannel[]
  texts         ProductText[]
  lots          InventoryLot[]
  movements     InventoryMovement[]
  orderItems    SalesOrderItem[]
  channelLinks  ChannelProductLink[]
  channelPrices ProductChannelPrice[]
  channelTexts  ChannelProductText[]
  returns       ReturnCase[]
  backorders    BackorderLine[]
  purchaseItems PurchaseOrderItem[]

  @@unique([storeId, ean])
  @@index([storeId, brand, model])
  @@map("products")
}

model EanAlias {
  id        String         @id @default(cuid())
  storeId   String
  productId String
  ean       String
  source    EanAliasSource @default(manual)
  note      String?
  createdAt DateTime       @default(now())

  store   Store   @relation(fields: [storeId], references: [id])
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([storeId, ean])
  @@index([productId])
  @@map("ean_aliases")
}

model SalesChannel {
  id           String        @id @default(cuid())
  storeId      String
  code         String
  name         String
  type         ChannelType
  status       ChannelStatus @default(active)
  feePercent   Decimal?      @db.Decimal(8, 4)
  cpaFixed     Decimal?      @db.Decimal(14, 2)
  payoutTerms  String?
  countryCode  String?
  currencyCode String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  store         Store                 @relation(fields: [storeId], references: [id])
  products      ProductChannel[]
  texts         ProductText[]
  orders        SalesOrder[]
  payouts       Payout[]
  productLinks  ChannelProductLink[]
  productPrices ProductChannelPrice[]
  productTexts  ChannelProductText[]

  @@unique([storeId, code])
  @@map("sales_channels")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  imageUrl  String
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

model ChannelProductLink {
  id                String   @id @default(cuid())
  productId         String
  salesChannelId    String
  productUrl        String?
  externalProductId String?
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesChannel SalesChannel @relation(fields: [salesChannelId], references: [id], onDelete: Cascade)

  @@unique([productId, salesChannelId])
  @@map("channel_product_links")
}

model ProductChannelPrice {
  id             String    @id @default(cuid())
  productId      String
  salesChannelId String
  priceAmount    Decimal   @db.Decimal(14, 2)
  currencyCode   String
  isActive       Boolean   @default(true)
  effectiveFrom  DateTime?
  effectiveTo    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesChannel SalesChannel @relation(fields: [salesChannelId], references: [id], onDelete: Cascade)

  @@index([productId, salesChannelId, isActive])
  @@map("product_channel_prices")
}

model ChannelProductText {
  id             String   @id @default(cuid())
  productId      String
  salesChannelId String
  locale         String
  title          String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  salesChannel SalesChannel @relation(fields: [salesChannelId], references: [id], onDelete: Cascade)

  @@unique([productId, salesChannelId, locale])
  @@index([salesChannelId, locale])
  @@map("channel_product_texts")
}

model ProductChannel {
  id                String               @id @default(cuid())
  productId         String
  channelId         String
  listingStatus     ChannelListingStatus @default(active)
  publicName        String?
  channelEan        String?
  listingUrl        String?
  priceOriginal     Decimal?             @db.Decimal(14, 2)
  priceCurrencyCode String?
  priceFxToEur      Decimal?             @db.Decimal(14, 6)
  priceEurFrozen    Decimal?             @db.Decimal(14, 2)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel SalesChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([productId, channelId])
  @@map("product_channels")
}

model ProductText {
  id          String   @id @default(cuid())
  storeId     String
  productId   String
  locale      String
  channelId   String?
  publicName  String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store   Store         @relation(fields: [storeId], references: [id])
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  channel SalesChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@unique([productId, locale, channelId])
  @@index([storeId, locale])
  @@map("product_texts")
}

model Warehouse {
  id        String          @id @default(cuid())
  storeId   String
  code      String
  name      String
  country   String?
  type      WarehouseType   @default(own)
  status    WarehouseStatus @default(active)
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  store     Store               @relation(fields: [storeId], references: [id])
  locations WarehouseLocation[]
  lots      InventoryLot[]
  movements InventoryMovement[]
  returns   ReturnCase[]

  @@unique([storeId, code])
  @@map("warehouses")
}

model WarehouseLocation {
  id          String   @id @default(cuid())
  warehouseId String
  code        String
  name        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  lots      InventoryLot[]

  @@unique([warehouseId, code])
  @@map("warehouse_locations")
}

model InventoryLot {
  id                String        @id @default(cuid())
  storeId           String
  productId         String
  warehouseId       String
  locationId        String?
  lotCode           String
  sourceType        LotSourceType @default(manual_receipt)
  status            LotStatus     @default(available)
  supplierName      String?
  purchasedAt       DateTime?
  receivedAt        DateTime      @default(now())
  quantityReceived  Int
  quantityAvailable Int
  unitCostOriginal  Decimal       @db.Decimal(14, 4)
  costCurrencyCode  String
  fxToEur           Decimal       @db.Decimal(14, 6)
  unitCostEurFrozen Decimal       @db.Decimal(14, 4)
  note              String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  store     Store               @relation(fields: [storeId], references: [id])
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  location  WarehouseLocation?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  movements InventoryMovement[]

  @@index([storeId, productId, receivedAt])
  @@index([warehouseId, productId])
  @@map("inventory_lots")
}

model InventoryMovement {
  id                String       @id @default(cuid())
  storeId           String
  productId         String
  lotId             String?
  warehouseId       String
  movementType      MovementType
  quantity          Int
  unitCostEurFrozen Decimal?     @db.Decimal(14, 4)
  referenceType     String?
  referenceId       String?
  reason            String?
  createdByUserId   String?
  createdAt         DateTime     @default(now())

  store     Store         @relation(fields: [storeId], references: [id])
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  lot       InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  createdBy User?         @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([storeId, productId, createdAt])
  @@index([storeId, warehouseId, createdAt])
  @@map("inventory_movements")
}

model Currency {
  code      String   @id
  name      String
  symbol    String?
  createdAt DateTime @default(now())

  storeCurrencies StoreCurrency[]
  fxBaseRates     FxRate[]        @relation("FxBase")
  fxQuoteRates    FxRate[]        @relation("FxQuote")

  @@map("currencies")
}

model Customer {
  id        String   @id @default(cuid())
  storeId   String
  email     String?
  fullName  String?
  country   String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store   Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders  SalesOrder[]
  tickets SupportTicket[]

  @@index([storeId, email])
  @@map("customers")
}

model SalesOrder {
  id                   String        @id @default(cuid())
  storeId              String
  orderNumber          String
  platform             String
  sourceChannelId      String?
  sourceLabel          String?
  customerId           String?
  customerCountryCode  String?
  currencyCode         String
  grossAmountOriginal  Decimal       @db.Decimal(14, 2)
  grossFxToEur         Decimal       @db.Decimal(14, 6)
  grossAmountEurFrozen Decimal       @db.Decimal(14, 2)
  feesEur              Decimal       @default(0) @db.Decimal(14, 2)
  cpaEur               Decimal       @default(0) @db.Decimal(14, 2)
  shippingCostEur      Decimal       @default(0) @db.Decimal(14, 2)
  packagingCostEur     Decimal       @default(0) @db.Decimal(14, 2)
  returnCostEur        Decimal       @default(0) @db.Decimal(14, 2)
  cogsEur              Decimal       @default(0) @db.Decimal(14, 2)
  netProfitEur         Decimal       @default(0) @db.Decimal(14, 2)
  status               OrderStatus   @default(pending)
  paymentStatus        PaymentStatus @default(unpaid)
  orderedAt            DateTime      @default(now())
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  store         Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sourceChannel SalesChannel?      @relation(fields: [sourceChannelId], references: [id], onDelete: SetNull)
  customer      Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items         SalesOrderItem[]
  payoutMatches PayoutOrderMatch[]
  invoice       Invoice?
  returns       ReturnCase[]
  backorders    BackorderLine[]
  tickets       SupportTicket[]
  webhookEvents IntegrationWebhookEvent[]

  @@unique([storeId, orderNumber])
  @@index([storeId, orderedAt])
  @@index([storeId, sourceChannelId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id                 String   @id @default(cuid())
  storeId            String
  orderId            String
  productId          String?
  productEan         String?
  title              String?
  quantity           Int
  unitPriceOriginal  Decimal  @db.Decimal(14, 2)
  fxToEur            Decimal  @db.Decimal(14, 6)
  unitPriceEurFrozen Decimal  @db.Decimal(14, 2)
  revenueEurFrozen   Decimal  @db.Decimal(14, 2)
  cogsEurFrozen      Decimal  @default(0) @db.Decimal(14, 2)
  createdAt          DateTime @default(now())

  store      Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order      SalesOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  backorders BackorderLine[]

  @@index([storeId, orderId])
  @@index([storeId, productId])
  @@map("sales_order_items")
}

model BackorderLine {
  id           String          @id @default(cuid())
  storeId      String
  orderId      String
  orderItemId  String?
  productId    String
  requestedQty Int
  fulfilledQty Int             @default(0)
  missingQty   Int
  status       BackorderStatus @default(open)
  note         String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order     SalesOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem SalesOrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([storeId, status, createdAt])
  @@index([storeId, productId, status])
  @@map("backorder_lines")
}

model Supplier {
  id                  String   @id @default(cuid())
  storeId             String
  code                String
  name                String
  contactName         String?
  contactEmail        String?
  city                String?
  country             String?
  defaultCurrencyCode String?
  paymentMethod       String?
  catalogUrl          String?
  vacationNote        String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@unique([storeId, code])
  @@index([storeId, isActive])
  @@map("suppliers")
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  storeId         String
  supplierId      String
  poNumber        String
  status          PurchaseOrderStatus @default(draft)
  orderedAt       DateTime            @default(now())
  expectedAt      DateTime?
  receivedAt      DateTime?
  trackingCode    String?
  trackingUrl     String?
  totalAmountEur  Decimal             @default(0) @db.Decimal(14, 2)
  note            String?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  store        Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplier     Supplier               @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  createdBy    User?                  @relation("PurchaseOrderCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items        PurchaseOrderItem[]
  payments     PurchaseOrderPayment[]
  shipments3pl ThreePlShipment[]

  @@unique([storeId, poNumber])
  @@index([storeId, status, orderedAt])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String   @id @default(cuid())
  storeId           String
  purchaseOrderId   String
  productId         String?
  title             String
  ean               String?
  quantityOrdered   Int
  quantityReceived  Int      @default(0)
  unitCostOriginal  Decimal  @db.Decimal(14, 4)
  currencyCode      String
  fxToEur           Decimal  @db.Decimal(14, 6)
  unitCostEurFrozen Decimal  @db.Decimal(14, 4)
  totalCostEur      Decimal  @db.Decimal(14, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([storeId, purchaseOrderId])
  @@index([storeId, productId])
  @@map("purchase_order_items")
}

model PurchaseOrderPayment {
  id              String   @id @default(cuid())
  storeId         String
  purchaseOrderId String
  paidAt          DateTime @default(now())
  currencyCode    String
  amountOriginal  Decimal  @db.Decimal(14, 2)
  fxToEur         Decimal  @db.Decimal(14, 6)
  amountEurFrozen Decimal  @db.Decimal(14, 2)
  note            String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  createdBy     User?         @relation("PurchasePaymentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([storeId, paidAt])
  @@index([storeId, purchaseOrderId])
  @@map("purchase_order_payments")
}

model ThreePlShipment {
  id              String   @id @default(cuid())
  storeId         String
  purchaseOrderId String?
  providerName    String
  referenceCode   String
  note            String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation("ThreePlCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  legs          ThreePlLeg[]

  @@unique([storeId, referenceCode])
  @@index([storeId, createdAt])
  @@map("three_pl_shipments")
}

model ThreePlLeg {
  id               String           @id @default(cuid())
  shipmentId       String
  legOrder         Int
  originLabel      String
  destinationLabel String
  trackingCode     String?
  trackingUrl      String?
  costCurrencyCode String?
  costOriginal     Decimal?         @db.Decimal(14, 2)
  fxToEur          Decimal?         @db.Decimal(14, 6)
  costEurFrozen    Decimal?         @db.Decimal(14, 2)
  status           ThreePlLegStatus @default(planned)
  departedAt       DateTime?
  deliveredAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  shipment ThreePlShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([shipmentId, legOrder])
  @@index([shipmentId, status])
  @@map("three_pl_legs")
}

model TeamTask {
  id               String       @id @default(cuid())
  storeId          String
  title            String
  description      String?
  status           TaskStatus   @default(open)
  priority         TaskPriority @default(medium)
  dueAt            DateTime?
  linkedEntityType String?
  linkedEntityId   String?
  assignedToUserId String?
  createdByUserId  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  closedAt         DateTime?

  store      Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  assignedTo User? @relation("TaskAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User? @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([storeId, status, priority])
  @@index([storeId, assignedToUserId, status])
  @@index([storeId, dueAt])
  @@map("team_tasks")
}

model UserPresence {
  id             String         @id @default(cuid())
  storeId        String
  userId         String
  status         PresenceStatus @default(online)
  lastSeenAt     DateTime       @default(now())
  lastEvent      String?
  lastPath       String?
  sessionStarted DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([storeId, lastSeenAt])
  @@index([storeId, status])
  @@map("user_presences")
}

model ChatChannel {
  id              String          @id @default(cuid())
  storeId         String
  code            String
  name            String
  type            ChatChannelType @default(public)
  isActive        Boolean         @default(true)
  createdByUserId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  store     Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("ChatChannelCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages  ChatMessage[]

  @@unique([storeId, code])
  @@index([storeId, isActive])
  @@map("chat_channels")
}

model ChatMessage {
  id               String   @id @default(cuid())
  storeId          String
  channelId        String
  userId           String
  body             String
  linkedEntityType String?
  linkedEntityId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store   Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storeId, channelId, createdAt])
  @@index([storeId, userId, createdAt])
  @@map("chat_messages")
}

model Notification {
  id               String               @id @default(cuid())
  storeId          String
  userId           String?
  type             NotificationType
  severity         NotificationSeverity @default(info)
  title            String
  body             String?
  linkedEntityType String?
  linkedEntityId   String?
  isRead           Boolean              @default(false)
  readAt           DateTime?
  createdByUserId  String?
  createdAt        DateTime             @default(now())

  store     Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User? @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User? @relation("NotificationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([storeId, userId, isRead, createdAt])
  @@map("notifications")
}

model SupportTicket {
  id                    String                @id @default(cuid())
  storeId               String
  customerId            String?
  orderId               String?
  title                 String
  description           String?
  channel               String?
  reason                String?
  status                SupportTicketStatus   @default(open)
  priority              SupportTicketPriority @default(medium)
  dueAt                 DateTime?
  assignedToUserId      String?
  createdByUserId       String?
  resolutionNote        String?
  firstResponseAt       DateTime?
  resolvedAt            DateTime?
  closedAt              DateTime?
  slaFirstResponseDueAt DateTime?
  slaResolutionDueAt    DateTime?
  slaBreached           Boolean               @default(false)
  slaBreachedAt         DateTime?
  slaBreachNotifiedAt   DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  store      Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer   Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order      SalesOrder?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  assignedTo User?               @relation("SupportTicketAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User?               @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  notes      SupportTicketNote[]

  @@index([storeId, status, priority, createdAt])
  @@index([storeId, assignedToUserId, status])
  @@index([storeId, dueAt])
  @@index([storeId, slaBreached, status])
  @@map("support_tickets")
}

model SupportTicketNote {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String?
  body      String
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@map("support_ticket_notes")
}

model Payout {
  id              String   @id @default(cuid())
  storeId         String
  channelId       String?
  payoutRef       String
  payoutDate      DateTime
  currencyCode    String
  amountOriginal  Decimal  @db.Decimal(14, 2)
  fxToEur         Decimal  @db.Decimal(14, 6)
  amountEurFrozen Decimal  @db.Decimal(14, 2)
  feesEur         Decimal  @default(0) @db.Decimal(14, 2)
  adjustmentsEur  Decimal  @default(0) @db.Decimal(14, 2)
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  store   Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  channel SalesChannel?      @relation(fields: [channelId], references: [id], onDelete: SetNull)
  matches PayoutOrderMatch[]

  @@unique([storeId, payoutRef])
  @@index([storeId, payoutDate])
  @@map("payouts")
}

model PayoutOrderMatch {
  id        String   @id @default(cuid())
  storeId   String
  payoutId  String
  orderId   String
  amountEur Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())

  store  Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  payout Payout     @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  order  SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([payoutId, orderId])
  @@index([storeId, orderId])
  @@map("payout_order_matches")
}

model Invoice {
  id             String        @id @default(cuid())
  storeId        String
  orderId        String        @unique
  invoiceNumber  String
  status         InvoiceStatus @default(issued)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime?
  currencyCode   String
  subtotalEur    Decimal       @db.Decimal(14, 2)
  taxEur         Decimal       @default(0) @db.Decimal(14, 2)
  totalEur       Decimal       @db.Decimal(14, 2)
  billingName    String?
  billingAddress String?
  billingCountry String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([storeId, invoiceNumber])
  @@index([storeId, issuedAt])
  @@map("invoices")
}

model ReturnCase {
  id                 String         @id @default(cuid())
  storeId            String
  orderId            String?
  productId          String?
  trackingCode       String?
  reason             String?
  labelPayer         String?
  conditionState     String?
  packagingRecovered Boolean        @default(false)
  decision           ReturnDecision @default(restock)
  status             ReturnStatus   @default(pending_review)
  quantity           Int            @default(1)
  returnCostEur      Decimal        @default(0) @db.Decimal(14, 2)
  warehouseId        String?
  processedByUserId  String?
  createdAt          DateTime       @default(now())
  processedAt        DateTime?

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order       SalesOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  product     Product?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  warehouse   Warehouse?  @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  processedBy User?       @relation(fields: [processedByUserId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([storeId, status])
  @@map("return_cases")
}

model StoreCurrency {
  id           String   @id @default(cuid())
  storeId      String
  currencyCode String
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyCode], references: [code], onDelete: Restrict)

  @@unique([storeId, currencyCode])
  @@map("store_currencies")
}

model FxRate {
  id                String   @id @default(cuid())
  storeId           String
  baseCurrencyCode  String
  quoteCurrencyCode String
  rate              Decimal  @db.Decimal(18, 8)
  rateDate          DateTime
  source            String?
  createdAt         DateTime @default(now())

  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  baseCurrency  Currency @relation("FxBase", fields: [baseCurrencyCode], references: [code], onDelete: Restrict)
  quoteCurrency Currency @relation("FxQuote", fields: [quoteCurrencyCode], references: [code], onDelete: Restrict)

  @@unique([storeId, baseCurrencyCode, quoteCurrencyCode, rateDate])
  @@index([storeId, rateDate])
  @@map("fx_rates")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  preferredLocale String   @default("es")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships         UserStoreMembership[]
  permissions         UserPermission[]
  refreshTokens       RefreshToken[]
  createdMovements    InventoryMovement[]
  processedReturns    ReturnCase[]
  purchaseOrders      PurchaseOrder[]        @relation("PurchaseOrderCreatedBy")
  purchasePayments    PurchaseOrderPayment[] @relation("PurchasePaymentCreatedBy")
  threePlShipments    ThreePlShipment[]      @relation("ThreePlCreatedBy")
  assignedTasks       TeamTask[]             @relation("TaskAssignedTo")
  createdTasks        TeamTask[]             @relation("TaskCreatedBy")
  presences           UserPresence[]
  chatChannelsCreated ChatChannel[]          @relation("ChatChannelCreatedBy")
  chatMessages        ChatMessage[]
  notifications       Notification[]         @relation("NotificationRecipient")
  notificationsSent   Notification[]         @relation("NotificationCreatedBy")
  assignedTickets     SupportTicket[]        @relation("SupportTicketAssignedTo")
  createdTickets      SupportTicket[]        @relation("SupportTicketCreatedBy")
  supportTicketNotes  SupportTicketNote[]
  auditLogs           AuditLog[]
  auditAnchors        AuditAnchor[] @relation("AuditAnchorCreatedBy")
  processedWebhooks   IntegrationWebhookEvent[] @relation("WebhookProcessedBy")
  processedOutbox     IntegrationOutboxEvent[]  @relation("OutboxProcessedBy")

  @@map("users")
}

model UserStoreMembership {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  roleKey   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId, roleKey])
  @@map("user_store_memberships")
}

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique
  description String?

  userPermissions UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  storeId      String
  permissionId String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  store      Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId, permissionId])
  @@index([storeId, userId])
  @@map("user_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  storeId    String
  userId     String?
  action     String
  entityType String
  entityId   String?
  message    String?
  payload    Json?
  prevHash   String?
  hashAlgo   String?  @default("sha256")
  hashChain  String?
  createdAt  DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([storeId, createdAt])
  @@index([storeId, action, createdAt])
  @@index([storeId, entityType, entityId, createdAt])
  @@map("audit_logs")
}

model AuditAnchor {
  id              String   @id @default(cuid())
  storeId         String
  anchorDay       String
  periodStart     DateTime
  periodEnd       DateTime
  eventCount      Int
  lastAuditLogId  String?
  lastHash        String?
  hashAlgo        String   @default("sha256")
  prevAnchorHash  String?
  anchorHash      String
  signature       String
  createdByUserId String?
  createdAt       DateTime @default(now())

  store     Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdBy User? @relation("AuditAnchorCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([storeId, anchorDay])
  @@index([storeId, createdAt])
  @@map("audit_anchors")
}

model StoreIntegration {
  id                String   @id @default(cuid())
  storeId           String
  provider          String
  isActive          Boolean  @default(true)
  webhookSecret     String?
  apiKey            String?
  configJson        Json?
  lastWebhookAt     DateTime?
  lastWebhookStatus String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  events IntegrationWebhookEvent[]
  outboxEvents IntegrationOutboxEvent[]

  @@unique([storeId, provider])
  @@index([storeId, isActive])
  @@map("store_integrations")
}

model IntegrationWebhookEvent {
  id                 String                 @id @default(cuid())
  storeId            String
  integrationId      String?
  provider           String
  topic              String
  externalEventId    String
  payloadHash        String
  signature          String?
  payload            Json
  status             IntegrationEventStatus @default(received)
  errorMessage       String?
  processedAt        DateTime?
  processedByUserId  String?
  salesOrderId       String?
  receivedAt         DateTime               @default(now())
  createdAt          DateTime               @default(now())

  store       Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  integration StoreIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  processedBy User?             @relation("WebhookProcessedBy", fields: [processedByUserId], references: [id], onDelete: SetNull)
  salesOrder  SalesOrder?       @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)

  @@unique([storeId, provider, externalEventId])
  @@index([storeId, status, receivedAt])
  @@index([storeId, topic, receivedAt])
  @@map("integration_webhook_events")
}

model IntegrationOutboxEvent {
  id                String                 @id @default(cuid())
  storeId           String
  integrationId     String?
  provider          String
  topic             String
  entityType        String
  entityId          String?
  dedupeKey         String
  payloadHash       String
  payload           Json
  status            IntegrationOutboxStatus @default(pending)
  attemptCount      Int                    @default(0)
  nextAttemptAt     DateTime               @default(now())
  lockedAt          DateTime?
  lastError         String?
  processedAt       DateTime?
  processedByUserId String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  store       Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  integration StoreIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  processedBy User?             @relation("OutboxProcessedBy", fields: [processedByUserId], references: [id], onDelete: SetNull)

  @@unique([storeId, provider, dedupeKey])
  @@index([storeId, status, nextAttemptAt])
  @@index([storeId, provider, createdAt])
  @@map("integration_outbox_events")
}
